generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SOVEREIGN
  ADMIN
  OPERATOR
  AUDITOR
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  businessName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  invoices    Invoice[]
  journalEntries JournalEntry[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(OPERATOR)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Invoice {
  id              String   @id @default(cuid())
  number          String?
  documentNumber  String?
  sifenCdc        String?
  sifenXmlUrl     String?
  issuedAt        DateTime
  type            String   // SALE, PURCHASE
  status          String   // APPROVED, PENDING, DRAFT
  totalAmount      Decimal  @db.Decimal(12,2)
  totalUSD        Decimal? @db.Decimal(12,2)
  exchangeRate    Decimal? @db.Decimal(12,4)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  customerId      String?
  items           InvoiceItem[]
  createdAt        DateTime @default(now())

  @@index([tenantId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id])
  sku         String
  quantity    Decimal  @db.Decimal(10,2)
  unitPrice   Decimal  @db.Decimal(12,2)
  totalPrice  Decimal  @db.Decimal(12,2)

  @@index([invoiceId])
}

model JournalEntry {
  id          String   @id @default(cuid())
  number      String
  date        DateTime
  description String
  status      String   // POSTED, DRAFT, VOIDED
  referenceType String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  lines        JournalLine[]
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

model JournalLine {
  id              String   @id @default(cuid())
  journalEntryId String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id])
  type            String   // DEBIT, CREDIT
  amount          Decimal  @db.Decimal(12,2)
  account         String
  createdAt        DateTime @default(now())

  @@index([journalEntryId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([entity, entityId])
}
