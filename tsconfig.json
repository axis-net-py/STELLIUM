{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@axis/core/*": ["../packages/core/*"],
      "@axis/core": ["../packages/core"],
      "@axis/accounting": ["../packages/accounting/src"],
      "@axis/currency": ["../packages/currency/src"],
      "@axis/dashboard": ["../packages/dashboard/src"],
      "@axis/reports": ["../packages/reports/src"],
      "@axis/sifen": ["./packages/sifen/lib"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
